# Copy to .env and fill in. Find these in Supabase → Project Settings → API.
# Only the anon/publishable key goes in the client — never the service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Shared entry passcode (gates the public URL). Pick your own.
VITE_APP_PASSCODE=changeme
